# Server Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=/api

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=tangacare
DB_SYNCHRONIZE=false
DB_LOGGING=true

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=7d

# OTP Configuration
OTP_EXPIRY_MINUTES=10

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:19006

# Rate Limiting (set RATE_LIMIT_ENABLED=false to disable in dev)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=400
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=60

# Reporting — cap line items returned on sales summary (default 2000)
SALES_SUMMARY_MAX_TRANSACTION_ROWS=2000

# RRA VSDC / EBM fiscal signing (optional; see OPERATIONS_RUNBOOK.md)
# Dry-run: leave RRA_EBM_ENABLED unset or false. Live: true + valid URL and credentials.
RRA_EBM_BASE_URL=https://ebm.rra.gov.rw
RRA_EBM_ENABLED=false
RRA_EBM_API_KEY=
RRA_EBM_DEVICE_SERIAL=
# Optional queue/retry tuning
# RRA_EBM_MAX_ATTEMPTS=5
# RRA_EBM_RETRY_BASE_MS=1500
# RRA_EBM_RETRY_MAX_MS=120000
# RRA_EBM_QUEUE_CLAIM_TTL_SECONDS=300
# RRA_EBM_QUEUE_BATCH_SIZE=50
# Pilot smoke script (yarn vsdc-pilot-smoke)
# PILOT_FACILITY_ID=
# SMOKE_API_BASE_URL=http://localhost:3000
# SMOKE_JWT=

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Tangacare" <noreply@tangacare.com>

# External Services (Optional - for future implementation)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
FIREBASE_PROJECT_ID=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
PAYPACK_CLIENT_ID=
PAYPACK_CLIENT_SECRET=

# Paypack Subscription Billing (Paypack transactions + webhooks)
# Generate access token dynamically from client credentials.
PAYPACK_CLIENT_ID=your-paypack-client-id
PAYPACK_CLIENT_SECRET=your-paypack-client-secret
PAYPACK_API_BASE_URL=https://payments.paypack.rw/api
PAYPACK_INITIATE_PATH=/transactions/cashin
PAYPACK_WEBHOOK_SIGN_KEY=your-paypack-webhook-signing-secret
# Used as `X-Webhook-Mode` when calling Paypack APIs.
PAYPACK_WEBHOOK_MODE=production

# Subscription grace/retry policy
SUBSCRIPTION_GRACE_DAYS=7
SUBSCRIPTION_MAX_ATTEMPTS=2

# Docker Configuration (Optional - for deployment)
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_NAME=tangacare-backend
DOCKER_TAG=latest

# Database Configuration
PGADMIN_EMAIL=admin@tangacare.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050