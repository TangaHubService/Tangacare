{
  "name": "tangacare-backend",
  "version": "1.0.0",
  "description": "Tangacare Telemedicine Platform Backend API",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "docs:generate": "ts-node scripts/generate-api-artifacts.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "typeorm:prod": "typeorm",
    "migration:generate": "yarn typeorm migration:generate -d src/config/database.ts",
    "migration:run": "yarn typeorm migration:run -d src/config/database.ts",
    "migration:run:prod": "yarn typeorm:prod migration:run -d dist/config/database.js",
    "migration:revert": "yarn typeorm migration:revert -d src/config/database.ts",
    "migration:revert:prod": "yarn typeorm:prod migration:revert -d dist/config/database.js",
    "migration:seed-table": "ts-node scripts/seed-migrations-table.ts",
    "migration:seed-table:prod": "node scripts/seed-migrations-table.js",
    "backfill:legacy-medicines": "ts-node scripts/backfill-legacy-medicine-organization.ts",
    "seed": "ts-node src/seeds/index.ts",
    "ensure-super-admin": "ts-node scripts/ensure-super-admin.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "telemedicine",
    "healthcare",
    "api",
    "typescript",
    "express",
    "typeorm",
    "postgresql"
  ],
  "author": "Tangacare Team",
  "license": "MIT",
  "dependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/socket.io": "^3.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.12",
    "@types/nodemailer": "^7.0.5",
    "pdfkit": "^0.17.2",
    "@types/pdfkit": "^0.17.4",
    "exceljs": "^4.4.0",
    "@types/exceljs": "^1.3.2",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.1.13",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "typeorm": "^0.3.19",
    "typescript": "^5.3.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.8.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=1.22.0"
  }
}
